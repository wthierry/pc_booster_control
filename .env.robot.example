# Copy to /home/booster/pc_booster_control/.env on robot.

# OpenAI key for /api/speak chat completion.
OPENAI_API_KEY=sk-replace-me

# Optional prompt tuning.
CHATGPT_SYSTEM_PROMPT=You are Booster K1's onboard assistant. Keep responses concise and practical.
BOOSTER_OPENAI_MODEL=gpt-4.1-mini

# Robot Piper defaults.
BOOSTER_PIPER_BIN=/home/booster/piper/piper/piper
BOOSTER_PIPER_VOICE_DIR=/home/booster/piper/voices
BOOSTER_PIPER_DEFAULT_VOICE=en_US-lessac-medium
BOOSTER_PIPER_PLAYBACK_MODE=aplay
BOOSTER_PIPER_APLAY_DEVICE=plughw:CARD=Device,DEV=0

# Optional TTS tuning (leave blank to disable).
# BOOSTER_PIPER_LENGTH_SCALE=1.2
# BOOSTER_PIPER_ESPEAK_VOICE=en-us

# Conversation daemon (wake word + STT + OpenAI + Piper).
BOOSTER_CONVERSATION_ENABLED=1
BOOSTER_CONVERSATION_USE_WAKE_WORD=1
BOOSTER_CONVERSATION_WAKE_WORD=hal
BOOSTER_CONVERSATION_VOICE_TYPE=en_US-lessac-medium
BOOSTER_CONVERSATION_WAKE_BEEP_ENABLED=1
BOOSTER_CONVERSATION_WAKE_BEEP_FREQ_HZ=880
BOOSTER_CONVERSATION_WAKE_BEEP_DURATION_MS=140
BOOSTER_SHERPA_KWS_TIMEOUT_SEC=1800
BOOSTER_SHERPA_STT_TIMEOUT_SEC=25
BOOSTER_SHERPA_DEVICE_NAME=plughw:CARD=Device,DEV=0
BOOSTER_SHERPA_ASR_MODEL_DIR=/home/booster/sherpa-onnx-models/sherpa-onnx-streaming-zipformer-en-2023-06-26
BOOSTER_SHERPA_WAKE_ALIASES=hal,hell,hall,howl

# Command contract:
# - Wake command exits 0 when wake word is detected.
# - STT command exits 0 and prints transcript to stdout.
# - "{wake_word}" is replaced by BOOSTER_CONVERSATION_WAKE_WORD in wake command.
BOOSTER_SHERPA_KWS_CMD=python3 scripts/sherpa_wake_once.py --wake-word "{wake_word}"
BOOSTER_SHERPA_STT_CMD=python3 scripts/sherpa_asr_once.py

# Web server bind.
BOOSTER_WEB_HOST=0.0.0.0
BOOSTER_WEB_PORT=8000
